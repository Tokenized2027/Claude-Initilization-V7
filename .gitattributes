# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for scripts and code (critical for Linux/mini PC)
*.sh text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
