# Orchestrator Configuration
# Copy to .env and fill in values

# Anthropic API key for spawning Claude agents
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# REQUIRED: Protects your API from unauthorized access.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# All requests must include header: X-API-Key: <this value>
ORCHESTRATOR_API_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# Memory system directory
CLAUDE_MEMORY_DIR=$HOME/claude-memory

# Context files directory (Linux: ~/Claude, Windows: ~/Desktop/Claude)
CLAUDE_RESOURCES_DIR=$HOME/Claude

# Orchestrator settings
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8000

# Auto-handoff: automatically spawn next agent when handoff is created
AUTO_HANDOFF=true

# Max concurrent agents
MAX_CONCURRENT_AGENTS=3

# Max auto-handoff chain depth (prevents infinite agent loops)
MAX_HANDOFF_DEPTH=5

# ── Budget Controls ──────────────────────────────────────────────────
# These prevent runaway API costs. The orchestrator blocks new agent spawns
# when a limit is hit. Check spend with GET /spend, reset with POST /spend/reset-project/{name}

# Max estimated spend per calendar day (all projects combined)
DAILY_BUDGET_USD=50.0

# Max estimated spend per project (cumulative, resets only manually)
PROJECT_BUDGET_USD=25.0

# Estimated cost per agent run (used for budget math — adjust based on your model/usage)
# Fallback cost estimate for unknown task types (USD per agent run).
# Known task types use per-route cost_estimate from project_routes.json instead.
ESTIMATED_COST_PER_AGENT_RUN=2.50

# ── Agent Timeout ────────────────────────────────────────────────────
# How long an agent can run before being killed. Default: 1800s (30 minutes).
# Dashboard builds typically take 10-20 minutes. Increase for complex tasks.
AGENT_TIMEOUT_SECONDS=1800

# Skip Claude Code permission prompts (DANGEROUS — allows agents to run any command)
# Only set to true if you fully trust the agent workflow and your network is secure
CLAUDE_SKIP_PERMISSIONS=false

# Failure notifications — pushes alert to Telegram bot webhook
# Requires telegram-bot service running (see telegram-bot/WEBHOOK_SETUP.md)
FAILURE_WEBHOOK_URL=http://127.0.0.1:8787/webhook

# ── Log Rotation ─────────────────────────────────────────────────────
# Max log files kept per project. Oldest are deleted when exceeded.
# Prevents disk fill on mini PC during extended autonomous operation.
MAX_LOGS_PER_PROJECT=200

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
