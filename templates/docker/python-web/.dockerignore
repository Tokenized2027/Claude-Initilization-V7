# =============================================================================
# .dockerignore — Python Web Application
# Keeps Docker build context small and prevents sensitive files from leaking
# =============================================================================

# Version control
.git
.gitignore

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
service-account.json

# Python artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node (if frontend assets exist)
node_modules/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Documentation
docs/
*.md
LICENSE

# Docker files (no need to copy these into the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.circleci/

# Misc
*.log
tmp/
temp/
.cache/
