# =============================================================================
# Production Dockerfile for Python Web Applications
# Template: Generic Python 3.12 multi-stage build
# Usage: Copy to your project root, customize as needed
# =============================================================================

# ---------------------
# Stage 1: Builder
# ---------------------
FROM python:3.12-slim AS builder

WORKDIR /build

# Install build dependencies (add system packages here if your pip packages need them)
RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ---------------------
# Stage 2: Production
# ---------------------
FROM python:3.12-slim AS production

# Runtime system dependencies (e.g., libpq for psycopg2)
RUN apt-get update && \
    apt-get install -y --no-install-recommends libpq5 curl && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd --gid 1000 appuser && \
    useradd --uid 1000 --gid appuser --shell /bin/bash --create-home appuser

WORKDIR /app

# Copy installed Python packages from builder
COPY --from=builder /install /usr/local

# Copy application source
COPY . .

# Remove files that should not be in the image
RUN rm -rf .env .env.* .git tests/ docs/ *.md

# Set ownership to non-root user
RUN chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8000

# Expose the application port
EXPOSE ${PORT}

# Health check — adjust the path to match your app's health endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:${PORT}/health || exit 1

# Default command — override in docker-compose.yml for your framework
# Examples:
#   Flask:   gunicorn --bind 0.0.0.0:${PORT} --workers 4 app:app
#   FastAPI: uvicorn main:app --host 0.0.0.0 --port ${PORT}
#   Django:  gunicorn --bind 0.0.0.0:${PORT} --workers 4 project.wsgi:application
CMD ["gunicorn", "--bind", "0.0.0.0:8000", "--workers", "4", "--timeout", "120", "app:app"]
