# Telegram Bot Configuration
# Copy to .env and fill in values

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_AUTHORIZED_USER_ID=YOUR_TELEGRAM_USER_ID

# Password hash — generate with: python3 generate-password-hash.py
# REQUIRED for security. Without this, the bot auto-authenticates (unsafe).
TELEGRAM_SESSION_PASSWORD_HASH=

# Session duration in seconds (default: 43200 = 12 hours)
TELEGRAM_SESSION_DURATION_SECONDS=43200

# Orchestrator connection
ORCHESTRATOR_URL=http://localhost:8000
ORCHESTRATOR_API_KEY=CHANGE_ME_SAME_AS_ORCHESTRATOR_ENV

# AI Conversational Mode (Claude)
# Uses the same ANTHROPIC_API_KEY as the orchestrator
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
TELEGRAM_AI_MODEL=claude-haiku-4-5-20251001
TELEGRAM_AI_MAX_TOKENS=1024
TELEGRAM_AI_ENABLED=true

# Voice Transcription (shared Whisper service)
# The Whisper Docker container runs on port 9000
# See whisper-service/README.md for setup
WHISPER_API_URL=http://127.0.0.1:9000
WHISPER_LANGUAGE=en

# Log file path
TELEGRAM_BOT_LOG=~/logs/telegram-bot.log

# Webhook server for proactive push notifications
TELEGRAM_WEBHOOK_PORT=8787
TELEGRAM_WEBHOOK_BIND=127.0.0.1
